# Per-run AF3 outputs (huge model files, regenerable)
runs/*/results/

# SLURM logs per run (noisy, regenerable)
runs/*/logs/

# Pair input JSONs (regenerable from proteins.faa via 01_generate_pair_jsons.py)
runs/*/data/pair_jsons/

# Legacy top-level dirs (kept for back-compat with any pre-runs/ pipeline copies)
results/
logs/
data/pair_jsons/

# Python caches
__pycache__/
*.pyc

# OS
.DS_Store
